generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  trialStart   DateTime @default(now()) @map("trial_start")
  trialEnd     DateTime @map("trial_end")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  emailQueue EmailQueue[]

  @@map("users")
}

model EmailQueue {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  templateName String    @map("template_name")
  scheduledFor DateTime  @default(now()) @map("scheduled_for")
  sentAt       DateTime? @map("sent_at")
  status       String    @default("pending")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("email_queue")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("team")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

model SiteConfig {
  key   String @id
  value String

  @@map("site_config")
}

model Application {
  id              Int      @id @default(autoincrement())
  tier            String
  name            String
  email           String
  phone           String?
  location        String?
  trainingHistory String?  @map("training_history")
  goals           String?
  whyNow          String?  @map("why_now")
  status          String   @default("new")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("applications")
}
